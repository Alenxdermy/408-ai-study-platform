{
  "name": "408-exercises",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:mp-weixin": "uni build -p mp-weixin",
    "dev:h5": "uni -p h5",
    "build:h5": "uni build -p h5",
    "dev:server": "pnpm --dir server dev",
    "build:server": "pnpm --dir server build",
    "seed:questions": "pnpm --dir server seed:questions",
    "lint": "eslint \"**/*.{ts,vue}\" --ignore-pattern \"server/dist/**\" --ignore-pattern \"dist/**\" && pnpm --dir server lint",
    "test": "pnpm --dir server test"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5020120260710001",
    "@dcloudio/uni-components": "3.0.0-alpha-5020120260710001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5020120260710001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5020120260710001",
    "@dcloudio/uni-ui": "1.5.12",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/runtime-dom": "3.4.21",
    "axios": "^1.7.9",
    "pinia": "^2.3.1",
    "uview-plus": "^3.3.40",
    "vue": "^3.5.11"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.32",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5020120260710001",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
    "vite": "5.2.8",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  },
